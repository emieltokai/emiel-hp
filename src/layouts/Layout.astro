---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "児童発達支援エミエル｜愛知県東海市の発達支援施設",
  description = "愛知県東海市の児童発達支援施設エミエルです。0〜6歳のお子さまの発達をサポートします。言語・運動・感覚統合など専門的な支援を提供しています。",
} = Astro.props;

const siteUrl = "https://nextgrowth1.com";
const ogImage = `${siteUrl}/image/外観.png`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO基本 -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <!-- OGP（SNSシェア用） -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="児童発達支援エミエル" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- ファビコン -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
	<!-- 構造化データ -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ChildCare",
      "name": "児童発達支援エミエル",
      "description": "愛知県東海市の児童発達支援施設。0〜6歳のお子さまの発達をサポートします。",
      "url": "https://nextgrowth1.com",
      "telephone": "052-627-6333",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "名和町山畑3番地1",
        "addressLocality": "東海市",
        "addressRegion": "愛知県",
        "postalCode": "476-0002",
        "addressCountry": "JP"
      },
      "openingHours": ["Mo-We 09:00-17:00", "Fr 09:00-17:00"],
      "image": "https://nextgrowth1.com/image/外観.png"
    }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>